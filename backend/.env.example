PORT=3001
DB_PATH=./data/mtg.db

# Búsqueda: cache (local SQLite), live (Moxfield en tiempo real), auto (cache si hay datos)
SEARCH_MODE=cache

# Sincronización diaria (cron: minuto hora día mes día-semana)
SYNC_CRON=0 3 * * *
SYNC_TIMEZONE=America/Argentina/Buenos_Aires
SYNC_ENABLED=true
SYNC_ON_START=false
SYNC_MISSING_ON_START=true

# Throttling para no saturar la API de Moxfield
SYNC_PAGE_SIZE=50
SYNC_PAGE_DELAY_MS=300
SYNC_USER_DELAY_MS=500

# Opcional: cookie de sesión de moxfield.com si Cloudflare sigue bloqueando
# MOXFIELD_COOKIE=cf_clearance=...; __cf_bm=...
